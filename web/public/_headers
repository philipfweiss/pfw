# Served by Cloudflare Pages for every path (worldfall's safe set).
# CSP notes: Astro inlines small stylesheets into <style> tags, so style-src
# keeps 'unsafe-inline'; scripts are always external bundles, so script-src
# does not. img-src allows data: for the live-painting favicon swaps and
# blob: for the playground's uploaded pictures (object URLs); connect-src
# allows blob: so the playground's HTML export can read those uploads back.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
