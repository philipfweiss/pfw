---
import Base from "../layouts/Base.astro";

// The Margin cards: hover (or tap) a marked word in the bio and a small
// card introduces it, the worldfall Margin-reference idiom. kind/title/blurb
// plus an onward link shown in the card's foot (and followed by clicking
// the word itself, where there is one). img: "logo" images sit contained on
// the paper; "cover" images fill the card's top like a plate.
// Image sources (all served locally from public/cards/): the Netflix,
// Airbnb, and Spark marks via Wikimedia Commons; the DataJunction sign is
// its GitHub org avatar; Hoover Tower photo from Wikimedia Commons
// (CC BY-SA); the Minerva is a Herculaneum fresco, public domain.
const cards = {
  netflix: {
    kind: "Employer",
    title: "Netflix",
    blurb:
      "According to the Global Internet Phenomena Report, 15% of the world's downstream internet traffic is Netflix. I work on the offline half: the infrastructure that makes sense of it all afterward.",
    href: "https://netflixtechblog.com",
    link: "netflixtechblog.com",
    img: "/cards/netflix.svg",
    imgKind: "logo",
  },
  spark: {
    kind: "Technology",
    title: "Apache Spark",
    blurb:
      "The open-source engine most large companies use to compute over very large datasets. I work on the infrastructure that runs it at Netflix scale.",
    href: "https://spark.apache.org",
    link: "spark.apache.org",
    img: "/cards/spark.svg",
    imgKind: "logo",
  },
  airbnb: {
    kind: "Employer",
    title: "Airbnb",
    blurb:
      "Most people know Airbnb for the homes. It also has a quietly excellent data culture: Airflow, Superset, and Minerva all came from a relatively small data infrastructure group, where I spent six years.",
    href: "https://medium.com/airbnb-engineering",
    link: "the Airbnb tech blog",
    img: "/cards/airbnb.svg",
    imgKind: "logo",
  },
  minerva: {
    kind: "Project",
    title: "Minerva",
    blurb:
      "Airbnb's metrics platform and single source of truth: over 30,000 metrics and 4,000 dimensions, defined once and served consistently to every dashboard and decision.",
    href: "https://medium.com/airbnb-engineering/how-airbnb-achieved-metric-consistency-at-scale-f23cc53dea70",
    link: "Minerva blog post",
    more: [
      {
        label: "part two",
        href: "https://medium.com/airbnb-engineering/airbnb-metric-computation-with-minerva-part-2-9afe6695b486",
      },
      {
        label: "part three",
        href: "https://medium.com/airbnb-engineering/how-airbnb-enables-consistent-data-consumption-at-scale-1c0b6a8b9206",
      },
      { label: "my talk", href: "https://www.youtube.com/watch?v=JHQqi5fdo-s" },
    ],
    img: "/cards/minerva.jpg",
    imgKind: "logo",
  },
  datajunction: {
    kind: "Project",
    title: "DataJunction",
    blurb:
      "Netflix's open-source semantic layer: metrics and the data models behind them defined in SQL as a graph of nodes, with DJ working out the joins and writing the queries.",
    href: "https://github.com/DataJunction/dj",
    link: "github.com/DataJunction",
    img: "/cards/datajunction.png",
    imgKind: "logo",
  },
  stanford: {
    kind: "School",
    title: "Stanford University",
    blurb:
      "I received a BS in computer science in 2019 and an MS in 2022, which I finished while working. I studied artificial intelligence and minored in Chinese.",
    href: "https://cs.stanford.edu",
    link: "cs.stanford.edu",
    img: "/cards/stanford.png",
    imgKind: "logo",
  },
};
// Hidden-surface SEO: none of this appears on the page. The description is
// what a search result shows under the name; the JSON-LD tells the crawlers
// who this is in schema.org terms.
const description =
  "Philip Weiss is a Senior Software Engineer at Netflix. A decade of semantic layers and metrics platforms: Minerva at Airbnb, DataJunction at Netflix, plus Spark infrastructure and data developer tooling.";

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Philip Weiss",
  url: "https://philipweiss.net",
  image: "https://philipweiss.net/portrait.jpg",
  jobTitle: "Senior Software Engineer",
  worksFor: { "@type": "Organization", name: "Netflix" },
  alumniOf: { "@type": "CollegeOrUniversity", name: "Stanford University" },
  knowsAbout: [
    "Semantic layers",
    "Metrics platforms",
    "Apache Spark",
    "Analytics infrastructure",
    "Databases",
    "Distributed systems",
    "Data developer tooling",
  ],
  sameAs: [
    "https://github.com/philipfweiss",
    "https://www.linkedin.com/in/weissguy/",
    "https://www.youtube.com/watch?v=JHQqi5fdo-s",
  ],
};
---

<Base description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <main class="wrap">
    <div class="easel" aria-label="Watercolor self-portrait, painting itself in stages">
      {/* the stage is what centers vertically; the button hangs below it so
          the portrait itself aligns with the centered text column */}
      <div class="stage">
        <canvas id="painting" width="1000" height="1000"></canvas>
        <div class="actions">
          <button class="repaint" id="repaint" disabled>paint it again</button>
          <a class="playground-link" href="/autoportrait/">playground</a>
        </div>
      </div>
    </div>

    <section class="intro">
      <h1>Philip Weiss</h1>

      <div class="bio">
        <p>
          I'm a Senior Software Engineer on <a
            class="ref"
            data-card="netflix"
            href={cards.netflix.href}>Netflix</a
          >'s Data Platform, where I work on its semantic layer, <a
            class="ref ref-quiet"
            data-card="spark"
            href={cards.spark.href}>Spark</a
          > infrastructure, and the tooling data developers use every day.
        </p>
        <p>
          Semantic layers are the thread that runs through my career: I spent
          six years at <a
            class="ref"
            data-card="airbnb"
            href={cards.airbnb.href}>Airbnb</a
          > building <a
            class="ref"
            data-card="minerva"
            href={cards.minerva.href}>Minerva</a
          >, its metrics platform, and the thread continues with <a
            class="ref"
            data-card="datajunction"
            href={cards.datajunction.href}>DataJunction</a
          >, Netflix's open-source semantic layer.
        </p>
        <p>
          I studied computer science at <a
            class="ref"
            data-card="stanford"
            href={cards.stanford.href}>Stanford</a
          >, where I earned a BS and an MS, both focused on artificial
          intelligence, with a heavy side of systems and databases.
        </p>
      </div>

      <ul class="links">
        <li>
          <a href="https://github.com/philipfweiss">
            <span class="label">GitHub</span>
            <span class="value">github.com/philipfweiss</span>
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/weissguy/">
            <span class="label">LinkedIn</span>
            <span class="value">linkedin.com/in/weissguy</span>
          </a>
        </li>
        <li>
          {/* no address in the static HTML: the parts live in data-* and the
              mailto is assembled on first interaction (harvesters that don't
              run JS never see it) */}
          <a href="#" id="email-link" data-u="philipfweiss" data-d="gmail.com">
            <span class="label">Email</span>
            <span class="value">first name, then an f, then last name, at gmail</span>
          </a>
        </li>
      </ul>
    </section>
  </main>

  <script type="application/json" id="margin-cards" set:html={JSON.stringify(cards)} />
  <script src="../scripts/portrait.js"></script>
  {/* served from public/ unprocessed: Astro would inline a small bundled
      script into the HTML, which the CSP (script-src 'self') forbids */}
  <script is:inline defer src="/scripts/cards.js"></script>
</Base>
