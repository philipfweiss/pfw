---
import Base from "../layouts/Base.astro";

// The Margin cards: hover (or tap) a marked word in the bio and a small
// card introduces it, the worldfall Margin-reference idiom. kind/title/blurb
// plus an onward link shown in the card's foot (and followed by clicking
// the word itself, where there is one). img: "logo" images sit contained on
// the paper; "cover" images fill the card's top like a plate.
// Image sources (all served locally from public/cards/): the Netflix,
// Airbnb, and Spark marks via Wikimedia Commons; the DataJunction sign is
// its GitHub org avatar; Hoover Tower photo from Wikimedia Commons
// (CC BY-SA); the Minerva is a Herculaneum fresco, public domain.
const cards = {
  netflix: {
    kind: "Employer",
    title: "Netflix",
    blurb:
      "Streaming, and a famously large amount of data about what the world watches. The Data Platform is the org that keeps that data fast, correct, and usable.",
    href: "https://netflixtechblog.com",
    link: "netflixtechblog.com",
    img: "/cards/netflix.svg",
    imgKind: "logo",
  },
  spark: {
    kind: "Technology",
    title: "Apache Spark",
    blurb:
      "The open-source engine most large companies use to compute over very large datasets. I work on the infrastructure that runs it at Netflix scale.",
    href: "https://spark.apache.org",
    link: "spark.apache.org",
    img: "/cards/spark.svg",
    imgKind: "logo",
  },
  airbnb: {
    kind: "Employer",
    title: "Airbnb",
    blurb:
      "Where I spent six years. Most people remember the treehouses; I remember twelve thousand metrics finally agreeing with each other.",
    href: "https://medium.com/airbnb-engineering",
    link: "the Airbnb tech blog",
    img: "/cards/airbnb.svg",
    imgKind: "logo",
  },
  minerva: {
    kind: "Project",
    title: "Minerva",
    blurb:
      "Airbnb's metrics platform: thousands of metrics defined once and computed consistently everywhere they appear. The project that taught me what a semantic layer has to be.",
    href: "https://medium.com/airbnb-engineering/how-airbnb-achieved-metric-consistency-at-scale-f23cc53dea70",
    link: "the Airbnb tech blog",
    img: "/cards/minerva.jpg",
    imgKind: "cover",
  },
  datajunction: {
    kind: "Project",
    title: "DataJunction",
    blurb:
      "Netflix's open-source semantic layer: metrics and the data models behind them defined in SQL as a graph of nodes, with DJ working out the joins and writing the queries.",
    href: "https://github.com/DataJunction/dj",
    link: "github.com/DataJunction",
    img: "/cards/datajunction.png",
    imgKind: "logo",
  },
  stanford: {
    kind: "School",
    title: "Stanford University",
    blurb:
      "A BS and an MS in computer science, both focused on artificial intelligence. Twenty-five technical courses on the transcript, and it's CS145 (Databases) that ended up running my life.",
    href: "https://cs.stanford.edu",
    link: "cs.stanford.edu",
    img: "/cards/stanford.jpg",
    imgKind: "cover",
  },
};
---

<Base>
  <main class="wrap">
    <div class="easel" aria-label="Watercolor self-portrait, painting itself in stages">
      <canvas id="painting" width="1000" height="1000"></canvas>
      <div class="actions">
        <button class="repaint" id="repaint" disabled>paint it again</button>
      </div>
    </div>

    <section class="intro">
      <h1>Philip <span class="wash">Weiss</span></h1>

      <div class="bio">
        <p>
          I'm a Senior Software Engineer on <a
            class="ref"
            data-card="netflix"
            href={cards.netflix.href}>Netflix</a
          >'s Data Platform, where I work on semantic layers, <a
            class="ref ref-quiet"
            data-card="spark"
            href={cards.spark.href}>Spark</a
          > infrastructure, and the tooling data developers use every day.
        </p>
        <p>
          Semantic layers are the thread that runs through my career: I spent
          six years at <a
            class="ref"
            data-card="airbnb"
            href={cards.airbnb.href}>Airbnb</a
          > building <a
            class="ref"
            data-card="minerva"
            href={cards.minerva.href}>Minerva</a
          >, its metrics platform, and I'm doing it again with <a
            class="ref"
            data-card="datajunction"
            href={cards.datajunction.href}>DataJunction</a
          >, Netflix's open-source semantic layer.
        </p>
        <p>
          I studied computer science at <a
            class="ref"
            data-card="stanford"
            href={cards.stanford.href}>Stanford</a
          >, a BS and an MS, both focused on artificial intelligence, with a
          heavy side of systems and databases.
        </p>
      </div>

      <ul class="links">
        <li>
          <a href="https://github.com/philipfweiss">
            <span class="label">GitHub</span>
            <span class="value">github.com/philipfweiss</span>
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/weissguy/">
            <span class="label">LinkedIn</span>
            <span class="value">linkedin.com/in/weissguy</span>
          </a>
        </li>
        <li>
          <a href="mailto:philipfweiss@gmail.com">
            <span class="label">Email</span>
            <span class="value">philipfweiss@gmail.com</span>
          </a>
        </li>
      </ul>
    </section>
  </main>

  <script type="application/json" id="margin-cards" set:html={JSON.stringify(cards)} />
  <script src="../scripts/portrait.js"></script>
  <script src="../scripts/cards.js"></script>
</Base>
