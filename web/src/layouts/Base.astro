---
import "@fontsource-variable/eb-garamond";
import "@fontsource-variable/inter";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Philip Weiss", description = "The personal page of Philip Weiss." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {/* the social card is the portrait mid-stroke (web/public/og.png,
        regenerated by tools/make_og.mjs) — the page, caught working */}
    <meta property="og:image" content={new URL("/og.png", Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
  </body>
</html>
